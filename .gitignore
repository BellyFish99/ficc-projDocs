# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.bak
*.bkp
.$*.bkp

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── What IS tracked (no entry needed — tracked by default) ───────────────────
# *.md        solution docs, PPT content, checkpoints, READMEs
# *.drawio    diagrams
# *.py        generation scripts
# *.txt       notes, key values
# *.json      manifests, config
# *.yaml      frontmatter
# *.mmd       mermaid diagrams
