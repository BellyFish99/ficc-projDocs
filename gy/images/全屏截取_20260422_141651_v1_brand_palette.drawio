        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A3A5C;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1600" height="900" as="geometry"/>
