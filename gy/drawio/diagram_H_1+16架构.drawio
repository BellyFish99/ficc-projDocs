        <!-- Title -->
        <mxCell id="10" value="&lt;b&gt;POMS 1 + 16 产品架构&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:11px;'&gt;1 个核心管理平台 + 16 大协同引擎  ·  覆盖国元五大跃升目标&lt;/font&gt;" style="fillColor=#0F2060;fontColor=#FFFFFF;strokeColor=none;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;html=1;" vertex="1" parent="1">
