        <mxCell id="sw" value="结论：国际厂商强在能力（Aladdin / Calypso / Murex 均 ●●●），但合规 / 成本 / 本土化红线&#10;国内自研（华泰 / 平安）强在本土化但不对外。华锐 POMS = 国际能力 + 国产替代 + 本土化 · 唯一选择" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a3a5c;strokeColor=#1a3a5c;fontColor=#FFFFFF;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="770" width="1480" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="foot" value="资料来源：各厂商官网 + IBSi 排行榜 + 华锐研究整理" style="text;html=1;align=center;fontSize=9;fillColor=none;strokeColor=none;fontColor=#999;" vertex="1" parent="1">
          <mxGeometry x="60" y="878" width="1480" height="15" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
