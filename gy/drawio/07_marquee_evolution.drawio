        </mxCell>
        <mxCell id="subt" value="30+ 年演进：内部交易风险管理 → 客户 API / Web 平台 → 构建机构客户生态" style="text;html=1;align=center;fontSize=12;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
