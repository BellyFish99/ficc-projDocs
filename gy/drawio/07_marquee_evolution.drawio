        <mxCell id="t" value="高盛 SecDB → Marquee：FICC 平台从内部工具演进到对外能力输出的典范" style="text;html=1;align=center;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1a3a5c;" vertex="1" parent="1">
