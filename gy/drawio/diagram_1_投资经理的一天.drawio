        <mxCell id="14" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;html=1;" value="08:30&lt;br&gt;开盘前" vertex="1">
          <mxGeometry height="88" width="110" y="100" as="geometry" />
        </mxCell>
        <mxCell id="15" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;html=1;" value="&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 手工拼接 3 个系统导出的持仓文件&lt;br&gt;&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 等待 IT 跑批，09:10 才收到昨日净值&lt;br&gt;&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 晨会推迟，信息不对称" vertex="1">
          <mxGeometry height="88" width="430" x="114" y="100" as="geometry" />
        </mxCell>
        <mxCell id="16" parent="1" style="fillColor=#F0F5FF;strokeColor=#3B7DD8;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;html=1;" value="&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; POMS 自动聚合全资产持仓，&lt;b&gt;09:00 前就绪&lt;/b&gt;&lt;br&gt;&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 实时 NAV 与敞口一屏展示&lt;br&gt;&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 晨会数据秒级准备，决策更早" vertex="1">
          <mxGeometry height="88" width="530" x="548" y="100" as="geometry" />
        </mxCell>
        <mxCell id="17" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;html=1;" value="09:30&lt;br&gt;交易中" vertex="1">
          <mxGeometry height="88" width="110" y="190" as="geometry" />
        </mxCell>
        <mxCell id="18" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;html=1;" value="&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 电话确认交易员执行状态，效率极低&lt;br&gt;&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 无法实时追踪滑点与交易成本&lt;br&gt;&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 手工记录成交回报，易出错" vertex="1">
          <mxGeometry height="88" width="430" x="114" y="190" as="geometry" />
        </mxCell>
        <mxCell id="19" parent="1" style="fillColor=#F0F5FF;strokeColor=#3B7DD8;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;html=1;" value="&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 指令自动路由至 OEMS，&lt;b&gt;全程可视化&lt;/b&gt;&lt;br&gt;&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; TCA 实时监控执行质量与滑点&lt;br&gt;&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 成交回报自动入账，零人工" vertex="1">
          <mxGeometry height="88" width="530" x="548" y="190" as="geometry" />
        </mxCell>
        <mxCell id="20" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;html=1;" value="11:00&lt;br&gt;风控预警" vertex="1">
          <mxGeometry height="88" width="110" y="280" as="geometry" />
        </mxCell>
        <mxCell id="21" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;html=1;" value="&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 风控邮件延迟 20 分钟才到达&lt;br&gt;&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 需手工核查是否超限，沟通链路长&lt;br&gt;&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 高压市场中决策严重滞后" vertex="1">
          <mxGeometry height="88" width="430" x="114" y="280" as="geometry" />
        </mxCell>
        <mxCell id="22" parent="1" style="fillColor=#F0F5FF;strokeColor=#3B7DD8;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;html=1;" value="&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; CEP 引擎 &lt;b&gt;&amp;lt;100ms&lt;/b&gt; 触发分级预警&lt;br&gt;&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 一键查看违规详情与处置建议&lt;br&gt;&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 合规预检拦截问题指令于发出前" vertex="1">
          <mxGeometry height="88" width="530" x="548" y="280" as="geometry" />
        </mxCell>
        <mxCell id="23" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;html=1;" value="14:00&lt;br&gt;策略调仓" vertex="1">
          <mxGeometry height="88" width="110" y="370" as="geometry" />
        </mxCell>
        <mxCell id="24" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;html=1;" value="&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 量化模型运行需等待 60 分钟&lt;br&gt;&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 结果无法直接生成交易指令&lt;br&gt;&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 人工二次录入，错误率高" vertex="1">
          <mxGeometry height="88" width="430" x="114" y="370" as="geometry" />
        </mxCell>
        <mxCell id="25" parent="1" style="fillColor=#F0F5FF;strokeColor=#3B7DD8;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;html=1;" value="&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 高性能计算引擎 &lt;b&gt;秒级&lt;/b&gt; 出再平衡结果&lt;br&gt;&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 自动生成指令包，一键批量审批&lt;br&gt;&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 推送执行，端到端 &amp;lt;5 分钟" vertex="1">
          <mxGeometry height="88" width="530" x="548" y="370" as="geometry" />
        </mxCell>
        <mxCell id="26" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;html=1;" value="收盘&lt;br&gt;归因复盘" vertex="1">
          <mxGeometry height="88" width="110" y="460" as="geometry" />
        </mxCell>
        <mxCell id="27" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;html=1;" value="&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 绩效归因 T+1 人工完成&lt;br&gt;&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 数据口径不一致，争议多&lt;br&gt;&lt;font color=&#39;#c62828&#39;&gt;▪&lt;/font&gt; 决策链路无法完整追溯" vertex="1">
          <mxGeometry height="88" width="430" x="114" y="460" as="geometry" />
        </mxCell>
        <mxCell id="28" parent="1" style="fillColor=#F0F5FF;strokeColor=#3B7DD8;strokeWidth=1;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;html=1;" value="&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; IBOR 实时更新，&lt;b&gt;T+0 归因&lt;/b&gt;&lt;br&gt;&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 多维归因自动生成，口径统一&lt;br&gt;&lt;font color=&#39;#2e7d32&#39;&gt;▶&lt;/font&gt; 完整决策链路可审计、可追溯" vertex="1">
          <mxGeometry height="88" width="530" x="548" y="460" as="geometry" />
        </mxCell>
        <mxCell id="29" parent="1" style="fillColor=#EEF3FA;strokeColor=#3B7DD8;strokeWidth=2;fontSize=12;fontStyle=0;align=center;verticalAlign=middle;rounded=1;html=1;" value="&lt;b&gt;核心转变：&lt;/b&gt; 从 &lt;font color=&#39;#c62828&#39;&gt;&lt;b&gt;手工拼数据 · 事后归因 · 决策滞后&lt;/b&gt;&lt;/font&gt;  →  &lt;font color=&#39;#2e7d32&#39;&gt;&lt;b&gt;实时感知 · 系统执行 · 闭环驱动&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="1080" y="556" as="geometry" />
        </mxCell>
