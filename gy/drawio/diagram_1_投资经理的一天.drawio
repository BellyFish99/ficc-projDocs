        <mxCell id="10" parent="1" style="fillColor=#2B5EC7;strokeColor=#1B3275;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;html=1;fontColor=#FFFFFF;" value="&lt;b&gt;投资经理的一天&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:11px;&#39;&gt;从手工拼数据到实时闭环驱动 — 有无 POMS 全天对比&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="1080" as="geometry" />
        </mxCell>
