        <mxCell id="13" parent="1" style="fillColor=#1B3275;fontColor=#FFFFFF;strokeColor=none;fontSize=13;fontStyle=1;align=center;html=1;" value="&lt;b&gt;✅  有 POMS 之后&lt;/b&gt;" vertex="1">
