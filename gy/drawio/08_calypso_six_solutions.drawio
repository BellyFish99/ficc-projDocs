        <mxCell id="s3h" value="③ 中台风险&#10;Middle-Office Risk" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#2e75b6;strokeColor=#2e75b6;fontColor=#FFFFFF;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
