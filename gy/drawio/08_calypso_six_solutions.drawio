        <mxCell id="s1h" value="① 前台工作站&#10;Front-Office" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a3a5c;strokeColor=#1a3a5c;fontColor=#FFFFFF;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
